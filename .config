# ==========================================================
# 🛰️ 核心目标系统设置 (修改为 U60p 对应的高通轻量级无线架构)
# ==========================================================
CONFIG_TARGET_qualcomm=y
CONFIG_TARGET_qualcomm_arm=y
CONFIG_TARGET_DEVICE_qualcomm_arm_DEVICE_generic=y

# 核心文件系统（随身WiFi标准格式）
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ==========================================================
# ⚡ U60p 必备的随身 Wi-Fi 专属网络与 USB 驱动
# ==========================================================
CONFIG_PACKAGE_kmod-usb-net=y
CONFIG_PACKAGE_kmod-usb-net-rndis=y        # 支持通过USB共享网络给电脑
CONFIG_PACKAGE_kmod-usb-net-cdc-ether=y    # 标准网卡模式
CONFIG_PACKAGE_kmod-usb-serial=y
CONFIG_PACKAGE_kmod-usb-serial-option=y   # 认出内置 eSIM/SIM 卡槽基带的关键
CONFIG_PACKAGE_kmod-usb-serial-wwan=y
CONFIG_PACKAGE_kmod-ath=y                  # 高通无线Wi-Fi芯片驱动

# ==========================================================
# 🌐 LuCI 图形界面与轻量化本地化
# ==========================================================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_LUCI_LANG_zh_Hans=y                 # 简体中文包
CONFIG_PACKAGE_luci-theme-argon=y          # 经典好看的 Argon 主题

# ==========================================================
# 📦 U60p 专属精简插件包 (随身WiFi内存小，只留核心，拒绝臃肿)
# ==========================================================
CONFIG_PACKAGE_luci-app-opkg=y             # 网页端软件包管理
CONFIG_PACKAGE_luci-app-firewall=y         # 防火墙
CONFIG_PACKAGE_luci-app-ttyd=y             # 网页终端（方便直接在网页切卡、锁频、发AT指令）
CONFIG_PACKAGE_luci-app-ramfree=y          # 内存一键释放（随身WiFi保命插件，防止内存爆掉断网）

# ==========================================================
# 🛠️ 底层实用工具
# ==========================================================
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_usbutils=y                  # lsusb 工具，用来排查硬件状态
CONFIG_PACKAGE_htop=y
